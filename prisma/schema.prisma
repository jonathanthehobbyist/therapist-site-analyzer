generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Analysis {
  id                 String   @id @default(cuid())
  createdAt          DateTime @default(now())
  siteUrl            String
  competitorUrl      String?
  keyword            String?
  status             String   @default("pending")
  progress           Int      @default(0)
  progressLabel      String?
  seoComparisonScore Int?
  seoHygieneScore    Int?
  hipaaRiskLevel     String?
  seoComparisonData  String?
  seoHygieneData     String?
  hipaaData          String?
  pagesScraped       String?
  error              String?
  isPublic           Boolean  @default(false)
  sharePasscode      String?
  loomUrl            String?
  overviewTitle      String?
  overviewSubtitle   String?
  customSeoTitle     String?
  customSeoDesc      String?
  customPagespeedTitle String?
  customPagespeedDesc  String?
  customHipaaTitle   String?
  customHipaaDesc    String?
  customKeywordsTitle String?
  customKeywordsDesc  String?
  customLocalSearchTitle String?
  customLocalSearchDesc  String?
  localSearchData    String?
  sectionModes       String?
  seoSummary         String?
  keywordData        String?
  pageSpeedData      String?
  site               Site?    @relation(fields: [siteId], references: [id])
  siteId             String?
  pageViews          SharePageView[]
}

model SharePageView {
  id              String   @id @default(cuid())
  analysisId      String
  analysis        Analysis @relation(fields: [analysisId], references: [id])
  sessionId       String
  referrer        String?
  deviceType      String
  userAgent       String?
  startedAt       DateTime @default(now())
  endedAt         DateTime?
  totalDurationMs Int?
  sectionViews    ShareSectionView[]
}

model ShareSectionView {
  id          String        @id @default(cuid())
  pageViewId  String
  pageView    SharePageView @relation(fields: [pageViewId], references: [id])
  section     String
  durationMs  Int
  viewOrder   Int
}

model IntakeSubmission {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  siteUrl    String
  email      String
  status     String   @default("pending") // pending | approved | rejected
  ipAddress  String
  analysisId String?
}

model Setting {
  key   String @id
  value String
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Site {
  id        String     @id @default(cuid())
  url       String     @unique
  label     String?
  createdAt DateTime   @default(now())
  analyses  Analysis[]
}
